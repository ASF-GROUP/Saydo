{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema/capability.json",
  "identifier": "default",
  "description": "Default capabilities for ASF Docket",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "fs:default",
    "fs:allow-exists",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-mkdir",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "$APPDATA/ASF Docket/**" }]
    }
  ]
}
